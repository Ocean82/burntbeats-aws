# Root .env for docker-compose. Copy to .env and fill in real values.
# NEVER commit .env — only .env.example (with placeholders) belongs in git.
# Individual services also have their own .env.example files.

# ── Frontend (Vite build args) ────────────────────────────────────────────────
# Clerk publishable key — safe to expose in frontend. Get from:
# https://dashboard.clerk.com → API Keys
VITE_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key_here

# Stripe publishable key — safe to expose in frontend. Get from:
# https://dashboard.stripe.com → Developers → API Keys
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# ── Backend ───────────────────────────────────────────────────────────────────
# Comma-separated allowed CORS origins. Set to your production domain.
FRONTEND_ORIGINS=https://yourdomain.com

# Optional: lock down the backend API with a shared secret (set in frontend too).
API_KEY=

# Optional: sign per-job tokens (recommended in production).
JOB_TOKEN_SECRET=

# ── Clerk (auth) ──────────────────────────────────────────────────────────────
# SECRET — never expose this in the frontend or commit the real value.
# Get from: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=your_clerk_secret_key_here

# ── Stripe (payments) ─────────────────────────────────────────────────────────
# SECRET — never expose this in the frontend or commit the real value.
# Get from: https://dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Webhook signing secret — Dashboard (prod) or Stripe CLI (local). Local: stripe login, then
#   bash scripts/stripe-listen.sh   (or: cd backend && npm run stripe:listen)
# Paste the printed whsec_... here.
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# Stripe account ID — from https://dashboard.stripe.com → Settings → Account details
STRIPE_ACCOUNT_ID=acct_xxxxxxxxxxxx

# ── Stripe price / product IDs ────────────────────────────────────────────────
# Create products at https://dashboard.stripe.com → Products

# Studio Quality Plan
STRIPE_PRICE_ID_STUDIO=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRODUCT_ID_STUDIO=prod_xxxxxxxxxxxxxxxxxxxx

# Premium Monthly
STRIPE_PRICE_ID_PREMIUM=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRODUCT_ID_PREMIUM=prod_xxxxxxxxxxxxxxxxxxxx

# Basic Monthly
STRIPE_PRICE_ID_BASIC=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRODUCT_ID_BASIC=prod_xxxxxxxxxxxxxxxxxxxx

# Top-Up Pack
STRIPE_PRICE_ID_TOPUP=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRODUCT_ID_TOPUP=prod_xxxxxxxxxxxxxxxxxxxx
