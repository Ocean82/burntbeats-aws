# Backend API base URL (no trailing slash). Used for stem split and stem file URLs.
VITE_API_BASE_URL=http://localhost:3001

# Optional: max upload size in bytes (must match backend MAX_UPLOAD_BYTES). Default 524288000 (500MB).
# VITE_MAX_UPLOAD_BYTES=524288000

# Backend API_KEY is server-only — never add a VITE_* copy; the browser must not hold that secret.

# Clerk publishable key (required for auth). Get from https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dev only: set to 1 to open the full stem app without signing in or Stripe (local QA).
# Never set in production. Requires `npm run dev` (Vite dev server).
# VITE_LOCAL_DEV_FULL_APP=1

# Playwright E2E (`npm run test:e2e`):
# Default URL is http://127.0.0.1:5180 so tests do not fight a normal `npm run dev` on 5173.
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:5180
# Point at your existing dev server on 5173 instead (must match; set VITE_LOCAL_DEV_FULL_APP=1 there):
# PLAYWRIGHT_BASE_URL=http://127.0.0.1:5173
# PLAYWRIGHT_REUSE_SERVER=1

# Optional: Google Analytics 4 (G-xxxxxxxxxx). Baked into the bundle at build time.
# VITE_GA_MEASUREMENT_ID=

# Stripe publishable key (pricing table + checkout). Get from https://dashboard.stripe.com
# Must match backend STRIPE_SECRET_KEY mode: pk_test_... with sk_test_..., pk_live_... with sk_live_...
# For local dev, use Test mode in the Stripe Dashboard and pk_test_... only.
# Production: use pk_live_ + sk_live_; the app warns in the console if pk_test_ is used in a production build.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Pricing table ID from Stripe Dashboard → Product catalog → Pricing tables
VITE_STRIPE_PRICING_TABLE_ID=prctbl_xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: Customer portal login link (Dashboard → Customer portal → Login link, in Test mode).
# Leave unset to use POST /api/billing/portal with your test keys instead.
# VITE_STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/xxxxxxxx

# Optional: Full external pricing page URL opened from the in-app header button.
# Example: https://www.burntbeats.com/pricing or a separate microsite.
# VITE_FULL_PRICING_URL=https://www.burntbeats.com/pricing

# Optional: enable server-side master export endpoint (/api/stems/server-export).
# Leave unset/0 unless backend has SERVER_EXPORT_ENABLED=1.
# VITE_SERVER_EXPORT_ENABLED=0
