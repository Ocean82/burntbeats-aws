# Stem service environment variables.
# Copy to `stem_service/.env` and adjust for your deployment.

# Comma-separated list of allowed origins for CORS.
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# Where split/expand outputs are written (must match backend STEM_OUTPUT_DIR).
STEM_OUTPUT_DIR=/path/to/burntbeats-aws/tmp/stems

# File for JSONL metrics logs (one JSON record per line).
STEM_METRICS_LOG=/path/to/burntbeats-aws/job_metrics.jsonl

# Which separation backend/pipeline mode to use.
STEM_BACKEND=hybrid

# SCNet (optional). Default 4-stem path is PyTorch htdemucs only (FOUR_STEM_BACKEND=hybrid).
USE_SCNET=1
# 4-stem: "hybrid" skips SCNet. "auto" tries PyTorch SCNet (if repo + checkpoint exist), then ONNX, then Demucs.
FOUR_STEM_BACKEND=hybrid
# ONNX: optional explicit file; else models/scnet_models/scnet.onnx, then models/scnet.onnx/scnet.onnx
# SCNET_ONNX=
# PyTorch: clone https://github.com/starrytong/SCNet — SCNET_REPO or models/SCNet or models/scnet_models/SCNet
# SCNET_REPO=
# SCNET_TORCH_CHECKPOINT defaults to models/scnet_models/scnet.th
# SCNET_TORCH_CONFIG defaults to models/scnet_models/config.yaml, else packaged scnet_musdb_default.yaml

# VAD pre-trim behavior.
USE_VAD_PRETRIM=true

# Enable VAD chunking for long inputs.
USE_VAD_CHUNKS=0
VAD_CHUNK_LENGTH_S=30
VAD_CHUNK_SILENCE_FLUSH_S=5.0

# Optional: native 2-stem via audio-separator CLI (pip install audio-separator). Often faster than
# vocal ONNX + phase inversion for Kim/UVR-style models. Runs after MDX23C rank0 (if any), before rank1 ONNX.
# USE_AUDIO_SEPARATOR_2STEM=1
# AUDIO_SEPARATOR_EXE=C:\path\to\audio-separator.exe
# AUDIO_SEPARATOR_TIMEOUT_SEC=600

# ONNX runtime behavior.
USE_ONNX_CPU=1
ONNXRUNTIME_NUM_THREADS=
# Intel OpenVINO execution provider (requires an ONNX Runtime build that includes it, e.g. onnxruntime-openvino).
# Ignored when USE_ONNX_CPU=1 (CPU-only path).
# USE_ONNX_OPENVINO=1

# MDX model quantization.
USE_INT8_ONNX=1
# 2-stem stage1: run second ONNX instrumental pass in addition to vocal ONNX.
# Default is disabled in code for faster turnaround; set to 1 to re-enable.
# USE_TWO_STEM_INST_ONNX_PASS=1

# Whether to use GPU acceleration (auto/1/true/yes or 0/false/no).
USE_GPU=auto

# Demucs 4-stem (CPU): mapped single-checkpoint .th per folder — see DEMUCS_SPEED_4STEM_CHECKPOINTS and
# DEMUCS_QUALITY_4STEM_CHECKPOINTS in stem_service/config.py (no env override; edit that tuple to change models).
# DEMUCS_QUALITY_BAG=single (default): skip YAML bags; use the mapped quality folders first.
# DEMUCS_QUALITY_BAG=auto or bags: allow ranked multi-model YAML bags under Demucs_Models again.
DEMUCS_QUALITY_BAG=single
USE_DEMUCS_SHIFTS_0=1

# Demucs subprocess: use stem_service.demucs_entry (mmap + thread env). Set 0 to use stock ``python -m demucs``.
USE_DEMUCS_BOOTSTRAP=1
# Optional: pin intra-op parallelism for the Demucs child (also sets OMP/MKL/OpenBLAS/NUMEXPR). Example: 10 or 12.
# DEMUCS_CPU_THREADS=10
# Optional alias for DEMUCS_CPU_THREADS.
# TORCH_CPU_THREADS=
# Inter-op parallel regions (PyTorch). If unset but DEMUCS_CPU_THREADS is set, defaults to 1 in demucs_entry.
# DEMUCS_INTEROP_THREADS=1
# Memory-map .th checkpoints on load (PyTorch 2.1+). Disable if a checkpoint fails to load.
DEMUCS_TORCH_LOAD_MMAP=1

# OpenVINO: PyTorch Demucs (.th) is not accelerated by ONNX/OpenVINO in this repo. For Intel/AMD CPU gains on
# MDX/SCNet paths, install an ORT build with OpenVINOExecutionProvider and set USE_ONNX_OPENVINO=1 (see above).

# Optional S3 upload after job completion.
# S3_ENABLED=true
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_PREFIX=stems
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_DELETE_LOCAL_AFTER_UPLOAD=false

# Token for protecting the stem service when reachable outside a trusted network.
# Must match the same value in backend.
# STEM_SERVICE_API_TOKEN=

# Ultra quality mode on CPU (slower but no GPU required).
# USE_ULTRA_ON_CPU=1

