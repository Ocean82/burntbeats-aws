# Stem service environment variables.
# Copy to `stem_service/.env` and adjust for your deployment.

# Comma-separated list of allowed origins for CORS.
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# Where split/expand outputs are written (must match backend STEM_OUTPUT_DIR).
STEM_OUTPUT_DIR=/path/to/burntbeats-aws/tmp/stems

# File for JSONL metrics logs (one JSON record per line).
STEM_METRICS_LOG=/path/to/burntbeats-aws/job_metrics.jsonl

# Which separation backend/pipeline mode to use.
STEM_BACKEND=hybrid

# SCNet ONNX (optional). Default 4-stem path is PyTorch htdemucs only (FOUR_STEM_BACKEND=hybrid).
USE_SCNET=1
# 4-stem: "hybrid" = PyTorch htdemucs for Stage 2 / expand (default). "auto" tries SCNet ONNX first when present.
FOUR_STEM_BACKEND=hybrid

# VAD pre-trim behavior.
USE_VAD_PRETRIM=true

# Enable VAD chunking for long inputs.
USE_VAD_CHUNKS=0
VAD_CHUNK_LENGTH_S=30
VAD_CHUNK_SILENCE_FLUSH_S=5.0

# ONNX runtime behavior.
USE_ONNX_CPU=1
ONNXRUNTIME_NUM_THREADS=

# MDX model quantization.
USE_INT8_ONNX=1
# 2-stem stage1: run second ONNX instrumental pass in addition to vocal ONNX.
# Default is disabled in code for faster turnaround; set to 1 to re-enable.
# USE_TWO_STEM_INST_ONNX_PASS=1

# Whether to use GPU acceleration (auto/1/true/yes or 0/false/no).
USE_GPU=auto

# Demucs settings used for quality mode.
DEMUCS_QUALITY_BAG=mdx_extra_q
USE_DEMUCS_SHIFTS_0=1

# Optional S3 upload after job completion.
# S3_ENABLED=true
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_PREFIX=stems
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_DELETE_LOCAL_AFTER_UPLOAD=false

# Token for protecting the stem service when reachable outside a trusted network.
# Must match the same value in backend.
# STEM_SERVICE_API_TOKEN=

# Ultra quality mode on CPU (slower but no GPU required).
# USE_ULTRA_ON_CPU=1

