# Stem service environment variables.
# Copy to `stem_service/.env` and adjust for your deployment.

# Comma-separated list of allowed origins for CORS.
FRONTEND_ORIGINS=http://localhost:5173,http://localhost:3000

# Where split/expand outputs are written (must match backend STEM_OUTPUT_DIR).
STEM_OUTPUT_DIR=/path/to/burntbeats-aws/tmp/stems

# File for JSONL metrics logs (one JSON record per line).
STEM_METRICS_LOG=/path/to/burntbeats-aws/job_metrics.jsonl

# Which separation backend/pipeline mode to use.
STEM_BACKEND=hybrid

# Expand 4-stem mode support (requires SCNet ONNX models in `models/`).
USE_SCNET=1

# VAD pre-trim behavior.
USE_VAD_PRETRIM=true

# Enable VAD chunking for long inputs.
USE_VAD_CHUNKS=0
VAD_CHUNK_LENGTH_S=30
VAD_CHUNK_SILENCE_FLUSH_S=5.0

# ONNX runtime behavior.
USE_ONNX_CPU=1
ONNXRUNTIME_NUM_THREADS=

# MDX model quantization.
USE_INT8_ONNX=1

# Whether to use GPU acceleration (auto/1/true/yes or 0/false/no).
USE_GPU=auto

# Demucs settings used for quality mode.
DEMUCS_QUALITY_BAG=mdx_extra_q
USE_DEMUCS_SHIFTS_0=1

