# Backend API env (optional). Copy to .env and set for server deployment.
# run-backend.sh sources backend/.env if present so PORT etc. match your security groups.
# Use these ports to align with EC2 security group (e.g. 8001) instead of changing the server.

# Port the backend listens on (default 3001). Set to 8001 to match server security group.
PORT=3001

# Stem service URL (default http://127.0.0.1:5000). Same host: 127.0.0.1:5000.
STEM_SERVICE_URL=http://127.0.0.1:5000

# Dir for stem output (must match stem service STEM_OUTPUT_DIR). Default: repo root tmp/stems
# STEM_OUTPUT_DIR=/path/to/burntbeats-aws/tmp/stems

# Time (ms) to wait for stem service to accept the split request (default 300000 = 5 min)
# SPLIT_ACCEPT_TIMEOUT_MS=300000

# CORS origins (comma-separated). Add your frontend and server IP/domain.
# FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174,https://burntbeats.com,http://52.0.207.242

# Optional API key for /api/stems/split (leave unset for no auth)
# API_KEY=
