# Backend API env (optional). Copy to .env and set for server deployment.
# run-backend.sh sources backend/.env if present so PORT etc. match your security groups.
# Use these ports to align with EC2 security group (e.g. 8001) instead of changing the server.

# Port the backend listens on (default 3001). Set to 8001 to match server security group.
PORT=3001

# Stem service URL (default http://127.0.0.1:5000). Same host: 127.0.0.1:5000.
STEM_SERVICE_URL=http://127.0.0.1:5000

# Dir for stem output (must match stem service STEM_OUTPUT_DIR). Default: repo root tmp/stems
# STEM_OUTPUT_DIR=/path/to/burntbeats-aws/tmp/stems

# Default maxAgeHours for POST /api/stems/cleanup when query param omitted (cron TTL). Default 24.
# STEM_CLEANUP_DEFAULT_MAX_AGE_HOURS=24

# Optional server-side master export (FFmpeg / compliance). Default off; app uses client-side export.
# SERVER_EXPORT_ENABLED=0

# Time (ms) to wait for stem service to accept the split request (default 300000 = 5 min)
# SPLIT_ACCEPT_TIMEOUT_MS=300000

# CORS origins (comma-separated). Add your frontend and server IP/domain.
# Also used to validate Stripe Checkout / Customer Portal returnUrl — production domain must be listed.
# FRONTEND_ORIGINS=http://localhost:5173,http://localhost:5174,https://burntbeats.com,http://52.0.207.242

# Optional malware scan (ClamAV) before split — upload stays in isolated temp; scan runs before stem_service.
# Install: Ubuntu `apt install clamav` then `freshclam`. Production: prefer `clamdscan` + clamd for speed.
# MALWARE_SCAN_ENABLED=1
# CLAMSCAN_BIN=clamdscan
# CLAMSCAN_ARGS=
# MALWARE_SCAN_TIMEOUT_MS=120000
# Append file path as last arg (default true). Set false only for custom scanner wrappers in tests.
# MALWARE_SCAN_APPEND_PATH=true

# Optional API key for /api/stems/split (leave unset for no auth)
# API_KEY=

# Optional API key for per-job request auth
# - The backend uses this to sign short-lived access tokens returned to the frontend.
# - Leave unset/empty to disable token enforcement (dev/local only).
# JOB_TOKEN_SECRET=
# JOB_TOKEN_TTL_MS=3600000

# Token for protecting the Python stem service when reachable outside a trusted network.
# This must be set to the same value in stem_service and backend.
# STEM_SERVICE_API_TOKEN=

# Optional Redis — shared webhook idempotency + per-period credit locks (multi-instance API).
# Same URL can be used for rate limiting if you add that later.
# REDIS_URL=redis://localhost:6379
# STRIPE_WEBHOOK_REDIS_URL=redis://localhost:6379

# Optional Redis-backed rate limiting (falls back to in-memory if unset).
# RATE_LIMIT_REDIS_URL=
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=10
# Note: GET /api/stems/status/:job_id is excluded from this global cap (split polling ~40/min).

# Optional: override accept timeout for expand (defaults to SPLIT_ACCEPT_TIMEOUT_MS).
# EXPAND_ACCEPT_TIMEOUT_MS=

# S3: stem_service uploads WAVs after each job; backend presigns GET /api/stems/file → redirect to S3.
# Configure the same bucket/region on stem_service and backend. Use IAM role or keys below.
# S3_ENABLED=true
# S3_BUCKET=your-bucket
# S3_REGION=us-east-1
# S3_PREFIX=stems
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# Optional: remove local stems after upload (backend must presign — needs AWS creds). Default false.
# S3_DELETE_LOCAL_AFTER_UPLOAD=false
# Presigned URL TTL for stem GET (seconds). Default 3600.
# S3_PRESIGN_EXPIRES_SECONDS=3600

# ── Usage tokens (split/expand debit) ───────────────────────────────────────
# 1 token = 1 minute of audio (partial minutes round up). E.g. 5:00 → 5 tokens.
# When enabled, POST /api/stems/split and /expand require Authorization: Bearer (Clerk JWT).
# USAGE_TOKENS_ENABLED=1
# USAGE_TOKENS_DEV_UNLIMITED=1
# Monthly grant (Stripe Price metadata tokens_per_month, or this default) — same token unit (minutes).
# USAGE_DEFAULT_TOKENS_PER_MONTH=6000

# ── Clerk (auth) ──────────────────────────────────────────────────────────────
# Required for JWT verification. Get from https://dashboard.clerk.com → API Keys.
CLERK_SECRET_KEY=your_clerk_secret_key_here

# ── Stripe (payments) ─────────────────────────────────────────────────────────
# Plan model (Basic vs Premium, monthly tokens, duration-based usage): docs/BILLING-AND-TOKENS.md
# Optional Price metadata: tokens_per_month, token_seconds_per_month, allow_4stem (see doc).
# Inspect prices: stripe prices retrieve price_xxx
#
# Local / safe testing: turn ON "Test mode" in the Stripe Dashboard (top right), then use
# sk_test_... and STRIPE_PRICE_ID_* values that exist in TEST mode only. Your frontend must use
# pk_test_... (VITE_STRIPE_PUBLISHABLE_KEY). Mixing live keys with test prices (or the reverse)
# makes checkout fail with Stripe API errors.
#
# Required for billing. Get from https://dashboard.stripe.com → Developers → API Keys.
STRIPE_SECRET_KEY=your_stripe_secret_key_here
# Webhook signing secret — local dev: `stripe login`, then from repo root `bash scripts/stripe-listen.sh`
# or from backend/ `npm run stripe:listen`. Copy the CLI’s whsec_... here.
# Production: Dashboard → Webhooks → endpoint signing secret.
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
# Stripe account ID — from https://dashboard.stripe.com → Settings → Account details
STRIPE_ACCOUNT_ID=acct_xxxxxxxxxxxx

# Stripe price IDs — create products at https://dashboard.stripe.com → Products
STRIPE_PRICE_ID_BASIC=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRODUCT_ID_BASIC=prod_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_PREMIUM=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRODUCT_ID_PREMIUM=prod_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_STUDIO=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRODUCT_ID_STUDIO=prod_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ID_TOPUP=price_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRODUCT_ID_TOPUP=prod_xxxxxxxxxxxxxxxxxxxx
